# .gitignore
#
# WHY: This prevents secrets, build artifacts, and local config from ever
# being committed. The most critical line is `.env` — committing your
# API key to a public repo means it will be found by bots within minutes
# and Anthropic will revoke it.

# ---- SECRETS (critical) ----
.env
.env.*
*.key
*.pem

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Testing ----
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# ---- Runtime data ----
gauntlet.db
*.db

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editors ----
.vscode/
.idea/
*.swp
*.swo
